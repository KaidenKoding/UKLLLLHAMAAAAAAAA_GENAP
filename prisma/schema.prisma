// Prisma Schema - Mie Gacoan Transaction System
// Jalankan: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================
// Enum: Role pengguna
// ==========================
enum Role {
  KASIR
  PEMBELI
}

// ==========================
// Model: User
// ==========================
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PEMBELI)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
}

// ==========================
// Model: Menu
// ==========================
model Menu {
  id        Int         @id @default(autoincrement())
  name      String
  price     Float
  stock     Int         @default(0)
  category  String      @default("mie") 
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orderItems OrderItem[]
}

// ==========================
// Model: Order (Header)
// ==========================
model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  totalPrice Float
  createdAt  DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
}

// ==========================
// Model: OrderItem (Detail)
// ==========================
model OrderItem {
  id       Int   @id @default(autoincrement())
  orderId  Int
  menuId   Int
  quantity Int
  price    Float

  order    Order @relation(fields: [orderId], references: [id])
  menu     Menu  @relation(fields: [menuId], references: [id])
}
